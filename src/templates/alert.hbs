{{#if show}}
<div style="
    padding: 16px;
    border-radius: 8px;
    margin: 16px 0;
    {{#ifEquals type 'warning'}}
    background: #fff3cd;
    border: 1px solid #ffc107;
    color: #856404;
    {{else ifEquals type 'error'}}
    background: #f8d7da;
    border: 1px solid #f5c6cb;
    color: #721c24;
    {{else ifEquals type 'success'}}
    background: #d4edda;
    border: 1px solid #c3e6cb;
    color: #155724;
    {{else}}
    background: #d1ecf1;
    border: 1px solid #bee5eb;
    color: #0c5460;
    {{/ifEquals}}
">
    <strong>{{title}}</strong>
    <p style="margin: 8px 0 0 0;">{{message}}</p>
</div>
{{/if}}